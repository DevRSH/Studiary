# Database
DATABASE_URL=sqlite+aiosqlite:////app/data/studiary.db

# Security
SECRET_KEY=CHANGE_ME_IN_PRODUCTION_LONG_RANDOM_STRING

# CORS (Railway URL)
CORS_ORIGINS=https://studiary.up.railway.app,https://yourdomain.com

# App
DEBUG=false
RAILWAY_ENVIRONMENT=production

# Rate Limiting
RATE_LIMIT_PER_MINUTE=100
