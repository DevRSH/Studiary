# ─── Application ──────────────────────────────────────────────────────────────
APP_NAME=Studiary API
APP_VERSION=1.0.0
DEBUG=false

# ─── Security (REQUIRED — generar con: openssl rand -hex 32) ─────────────────
SECRET_KEY=your-super-secret-key-change-this-in-production

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:///./data/studiary.db

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Lista separada por comas. En producción usar el dominio real.
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ─── Rate Limiting ────────────────────────────────────────────────────────────
RATE_LIMIT_PER_MINUTE=60

# ─── Nextcloud (Opcional) ─────────────────────────────────────────────────────
NEXTCLOUD_URL=
NEXTCLOUD_USERNAME=
NEXTCLOUD_PASSWORD=
